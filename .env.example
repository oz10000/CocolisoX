# Modo: BACKTEST, SIMULATION, LIVE_TESTNET, LIVE_MAINNET
TRADING_MODE=SIMULATION

# Exchange: binance, bybit
EXCHANGE=binance

# API Keys (dejar vacío para simulación)
API_KEY=
API_SECRET=

# Testnet
USE_TESTNET=false

# Proxy (opcional)
HTTP_PROXY=
HTTPS_PROXY=

# Parámetros de trading
SYMBOL=BTC/USDT
TIMEFRAME=5m
AMOUNT_PERCENT=10
LEVERAGE=1
STOP_LOSS_PCT=2
TAKE_PROFIT_PCT=0
MAX_DAILY_LOSS=5

# Backtest
BACKTEST_START=2025-01-01
BACKTEST_END=2025-02-01

# Simulación
SIMULATION_SLIPPAGE=0.001
SIMULATION_FEE=0.001

# IPs bloqueadas (separadas por coma)
BLOCKED_IPS=1.2.3.4,5.6.7.8
